# Kubernetes Functions
# Quick context switching with fzf
kctxf() {
    local context=$(kubectl config get-contexts -o name | fzf --height 40% --reverse)
    [[ -n "$context" ]] && kubectl config use-context "$context"
}

# Quick namespace switching with fzf
knsf() {
    local ns=$(kubectl get ns -o name | cut -d/ -f2 | fzf --height 40% --reverse)
    [[ -n "$ns" ]] && kubectl config set-context --current --namespace="$ns"
}

# Get all resources in namespace
kall() {
    kubectl api-resources --verbs=list --namespaced -o name | xargs -n 1 kubectl get --show-kind --ignore-not-found ${@}
}

# Watch pods with custom columns
kwp() {
    watch -n 1 "kubectl get pods -o custom-columns=NAME:.metadata.name,STATUS:.status.phase,RESTARTS:.status.containerStatuses[0].restartCount,AGE:.metadata.creationTimestamp ${@}"
}

# Quick pod exec
kexec() {
    local pod=$(kubectl get pods -o name | cut -d/ -f2 | fzf --height 40% --reverse)
    [[ -n "$pod" ]] && kubectl exec -it "$pod" -- ${@:-/bin/bash}
}

# Quick pod logs
klogs() {
    local pod=$(kubectl get pods -o name | cut -d/ -f2 | fzf --height 40% --reverse)
    [[ -n "$pod" ]] && kubectl logs -f "$pod" ${@}
}

# Docker Functions
# Quick docker exec with fzf
dexec() {
    local container=$(docker ps --format "table {{.Names}}" | tail -n +2 | fzf --height 40% --reverse)
    [[ -n "$container" ]] && docker exec -it "$container" ${@:-/bin/bash}
}

# Docker logs with fzf
dlogs() {
    local container=$(docker ps -a --format "table {{.Names}}" | tail -n +2 | fzf --height 40% --reverse)
    [[ -n "$container" ]] && docker logs -f "$container"
}

# Git Functions
# Interactive branch checkout
gcof() {
    local branch=$(git branch -a | fzf --height 40% --reverse | sed 's/^[* ]*//' | sed 's/^remotes\///')
    [[ -n "$branch" ]] && git checkout "$branch"
}

# Interactive commit browser
gshow() {
    git log --graph --color=always --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" |
    fzf --ansi --no-sort --reverse --tiebreak=index --bind=ctrl-s:toggle-sort \
        --bind "ctrl-m:execute:
            (grep -o '[a-f0-9]\{7\}' | head -1 |
            xargs -I % sh -c 'git show --color=always % | less -R') << 'FZF-EOF'
            {}
FZF-EOF"
}

